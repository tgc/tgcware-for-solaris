     reqbuf[req->offset] = '\0';
@@ -902,7 +902,7 @@ static int rtspd_send_doc(curl_socket_t sock, struct rtspd_httprequest *req)
       break;
     }
     else {
-      logmsg("Sent off %zd bytes", written);
