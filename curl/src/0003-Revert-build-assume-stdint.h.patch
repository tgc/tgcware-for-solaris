diff --git a/lib/formdata.c b/lib/formdata.c
index 3770d28b18..9618b723a0 100644
--- a/lib/formdata.c
+++ b/lib/formdata.c
@@ -309,7 +309,7 @@ static CURLFORMcode FormAdd(struct curl_httppost **httppost,
   struct curl_httppost *lastnode = NULL;
 
 #define form_ptr_arg(t) (forms ? (t)(void *)avalue : va_arg(params, t))
-#ifdef HAVE_UINTPTR_T
+#ifdef HAVE_STDINT_H
 #define form_int_arg(t) (forms ? (t)(uintptr_t)avalue : va_arg(params, t))
 #else
 #define form_int_arg(t) (forms ? (t)(void *)avalue : va_arg(params, t))
diff --git a/lib/hostip.h b/lib/hostip.h
index 6c7f1291b2..1817ec1ba3 100644
--- a/lib/hostip.h
+++ b/lib/hostip.h
@@ -28,6 +28,10 @@
 #include "hash.h"
