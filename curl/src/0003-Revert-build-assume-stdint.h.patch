From 908aa700e9eae0f74b518a4bdcc6f46b73919ff8 Mon Sep 17 00:00:00 2001
From: "Tom G. Christensen" <tgc@jupiterrise.com>
Date: Wed, 18 Mar 2026 21:15:58 +0100
Subject: [PATCH 3/6] Revert "build: assume `stdint.h`"

This reverts commit feb52be197c695fa783d68c11924f474c2add6b7.
---
 CMakeLists.txt             |  1 +
 configure.ac               |  1 +
 lib/config-win32.h         |  5 +++++
 lib/curl_config-cmake.h.in |  3 +++
 lib/curl_setup.h           | 10 +++-------
 lib/curlx/timeval.c        |  1 +
 lib/doh.h                  |  4 ++++
 lib/dynhds.h               |  1 +
 lib/formdata.c             |  2 +-
 lib/hostip.h               |  4 ++++
 lib/http.h                 |  5 +++++
 lib/http2.c                |  1 +
 lib/vtls/cipher_suite.h    |  1 +
 13 files changed, 31 insertions(+), 8 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 1eb64a9cd2..ba154979a6 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -1520,6 +1520,7 @@ check_include_file("poll.h"           HAVE_POLL_H)
 check_include_file("pwd.h"            HAVE_PWD_H)
 check_include_file("stdatomic.h"      HAVE_STDATOMIC_H)
 check_include_file("stdbool.h"        HAVE_STDBOOL_H)
+check_include_file("stdint.h"         HAVE_STDINT_H)
 check_include_file("strings.h"        HAVE_STRINGS_H)
 check_include_file("stropts.h"        HAVE_STROPTS_H)
 check_include_file("termio.h"         HAVE_TERMIO_H)
diff --git a/configure.ac b/configure.ac
index 6d2cb5583b..c69b24c917 100644
--- a/configure.ac
+++ b/configure.ac
@@ -4000,6 +4000,7 @@ AC_CHECK_HEADERS(
   libgen.h \
   locale.h \
   stdbool.h \
+  stdint.h \
   sys/filio.h \
   sys/eventfd.h,
 dnl to do if not found
diff --git a/lib/config-win32.h b/lib/config-win32.h
index ddde06a3ef..fd7d584d9a 100644
--- a/lib/config-win32.h
+++ b/lib/config-win32.h
@@ -46,6 +46,11 @@
 #define HAVE_STDBOOL_H 1
 #endif
 
+/* Define to 1 if you have the <stdint.h> header file. */
+#if defined(_MSC_VER) || defined(__MINGW32__)
+#define HAVE_STDINT_H 1
+#endif
+
 /* Define if you have the <sys/param.h> header file. */
 #ifdef __MINGW32__
 #define HAVE_SYS_PARAM_H 1
diff --git a/lib/curl_config-cmake.h.in b/lib/curl_config-cmake.h.in
index 1dcab9d897..6270eb1432 100644
--- a/lib/curl_config-cmake.h.in
+++ b/lib/curl_config-cmake.h.in
@@ -472,6 +472,9 @@
 /* Define to 1 if you have the sendmmsg function. */
 #cmakedefine HAVE_SENDMMSG 1
 
+/* Define to 1 if you have the <stdint.h> header file. */
+#cmakedefine HAVE_STDINT_H 1
+
 /* Define to 1 if you have the 'fsetxattr' function. */
 #cmakedefine HAVE_FSETXATTR 1
 
diff --git a/lib/curl_setup.h b/lib/curl_setup.h
index 4f8d65af8b..f9dcff9c37 100644
--- a/lib/curl_setup.h
+++ b/lib/curl_setup.h
@@ -499,8 +499,9 @@
 #include <curl/stdcheaders.h>
 #endif
 
+#if defined(HAVE_STDINT_H) || defined(USE_WOLFSSL)
 #include <stdint.h>
-#define HAVE_UINTPTR_T  /* assume uintptr_t is provided by stdint.h */
+#endif
 
 #ifdef __DJGPP__
 /* By default, DJGPP provides this type as a version of 'unsigned long' which
@@ -509,11 +510,6 @@
 #define uint32_t unsigned int
 #endif
 
-/* Disable uintptr_t for targets known to miss it from stdint.h */
-#ifdef __OS400__
-#undef HAVE_UINTPTR_T
-#endif
-
 #include <limits.h>
 
 #ifdef _WIN32
@@ -850,7 +846,7 @@
 
 /* Macro to strip 'const' without triggering a compiler warning.
    Use it for APIs that do not or cannot support the const qualifier. */
-#ifdef HAVE_UINTPTR_T
+#ifdef HAVE_STDINT_H
 #define CURL_UNCONST(p) ((void *)(uintptr_t)(const void *)(p))
 #else
 #define CURL_UNCONST(p) ((void *)(p))  /* Fall back to simple cast */
diff --git a/lib/curlx/timeval.c b/lib/curlx/timeval.c
index 435804c299..fe604ac846 100644
--- a/lib/curlx/timeval.c
+++ b/lib/curlx/timeval.c
@@ -117,6 +117,7 @@ void curlx_pnow(struct curltime *pnow)
 
 #elif defined(HAVE_MACH_ABSOLUTE_TIME)
 
+#include <stdint.h>
 #include <mach/mach_time.h>
 
 void curlx_pnow(struct curltime *pnow)
